# =============================================================
# modules/gesture_engine.py
#
# Reads 21 hand landmarks → outputs a single gesture string.
#
# WHAT THIS MODULE DOES:
#   - Calculates distances between fingertips
#   - Determines which fingers are extended (up) or folded (down)
#   - Combines these into named gestures
#   - Tracks gesture state over time (e.g. select_start vs select_end)
#
# GESTURE REFERENCE TABLE:
# ┌────────────────────────┬──────────────────────────────────────┐
# │ Gesture name           │ How it's detected                    │
# ├────────────────────────┼──────────────────────────────────────┤
# │ "none"                 │ No hand detected                     │
# │ "idle"                 │ Hand present but no specific gesture │
# │ "click"                │ Thumb tip + Index tip distance < threshold │
# │ "select_start"         │ Thumb tip + Middle tip meet (first)  │
# │ "select_end"           │ Thumb tip + Middle tip meet (again)  │
# │ "drag"                 │ Index + Middle fingers up, others down│
# │ "erase"                │ Closed fist (all fingers down)       │
# │ "draw"                 │ Only index finger extended           │
# │ "filter_next"          │ Open palm (all 5 fingers up)         │
# └────────────────────────┴──────────────────────────────────────┘
#
# HOW DISTANCE IS MEASURED:
#   Euclidean distance between two (x,y) points in pixel space.
#   math.hypot(x2-x1, y2-y1)
#   Compared against config.PINCH_THRESHOLD (default 35px)
#
# HOW "FINGER UP" IS DETECTED:
#   A finger is "up" if its tip is ABOVE its base joint (lower y value).
#   For the thumb: tip is to the LEFT of its base (x comparison).
# =============================================================

import math
import time
import config

from modules.hand_tracker import FINGERTIP_IDS, FINGERBASE_IDS, FINGERPIP_IDS


def distance(p1, p2):
    """Euclidean distance between two (x, y) points."""
    return math.hypot(p2[0] - p1[0], p2[1] - p1[1])


class GestureEngine:
    def __init__(self):
        self.threshold       = config.PINCH_THRESHOLD

        # Select gesture needs state tracking:
        # First middle+thumb pinch = select_start
        # Second middle+thumb pinch = select_end
        self._select_active  = False

        # Debounce: prevent a single pinch being detected as multiple events
        # Minimum time (seconds) between select events
        self._select_cooldown   = 0.6   # seconds
        self._last_select_time  = 0.0

        # Same debounce for click
        self._click_cooldown    = 0.3
        self._last_click_time   = 0.0

        # Track previous gesture to detect transitions
        self._prev_gesture   = "none"

        # Current gesture output
        self.gesture         = "none"

    # ----------------------------------------------------------
    # MAIN UPDATE — call once per frame
    # ----------------------------------------------------------
    def update(self, landmarks):
        """
        Compute current gesture from landmark list.

        Parameters:
            landmarks : list of 21 (x, y) tuples (from HandTracker)
                        or None if no hand detected

        Returns:
            gesture : str — one of the gesture names in the table above
        """
        if landmarks is None:
            self.gesture = "none"
            return self.gesture

        # Extract the points we care about most
        thumb_tip  = landmarks[FINGERTIP_IDS["thumb"]]
        index_tip  = landmarks[FINGERTIP_IDS["index"]]
        middle_tip = landmarks[FINGERTIP_IDS["middle"]]
        ring_tip   = landmarks[FINGERTIP_IDS["ring"]]
        pinky_tip  = landmarks[FINGERTIP_IDS["pinky"]]

        # Which fingers are extended?
        fingers_up = self._fingers_up(landmarks)

        # Calculate key pinch distances
        thumb_index_dist  = distance(thumb_tip, index_tip)
        thumb_middle_dist = distance(thumb_tip, middle_tip)

        now = time.time()

        # --------------------------------------------------
        # GESTURE PRIORITY ORDER
        # Checked from most specific → most general
        # --------------------------------------------------

        # 1. ERASE — closed fist (no fingers up)
        if sum(fingers_up) == 0:
            self.gesture = "erase"

        # 2. CLICK — thumb + index pinch
        elif thumb_index_dist < self.threshold:
            if now - self._last_click_time > self._click_cooldown:
                self._last_click_time = now
                self.gesture = "click"
            else:
                # Still in cooldown — treat as idle so cursor keeps moving
                self.gesture = "idle"

        # 3. SELECT — thumb + middle pinch (stateful: start / end)
        elif thumb_middle_dist < self.threshold:
            if now - self._last_select_time > self._select_cooldown:
                self._last_select_time = now
                if not self._select_active:
                    self._select_active = True
                    self.gesture = "select_start"
                else:
                    self._select_active = False
                    self.gesture = "select_end"
            else:
                self.gesture = "idle"

        # 4. FILTER NEXT — open palm (all 5 fingers up)
        elif sum(fingers_up) == 5:
            self.gesture = "filter_next"

        # 5. DRAW — only index finger extended
        elif fingers_up == [False, True, False, False, False]:
            self.gesture = "draw"

        # 6. DRAG — index + middle up, others down
        elif fingers_up == [False, True, True, False, False]:
            self.gesture = "drag"

        # 7. IDLE — hand detected but no specific gesture
        else:
            self.gesture = "idle"

        self._prev_gesture = self.gesture
        return self.gesture

    # ----------------------------------------------------------
    # HELPER: which fingers are currently extended?
    # ----------------------------------------------------------
    def _fingers_up(self, landmarks):
        """
        Returns a list of 5 booleans: [thumb, index, middle, ring, pinky]
        True = finger is extended (up), False = finger is folded (down)

        How it works:
        - For index/middle/ring/pinky: tip y < pip y means tip is higher
          on screen than the middle joint → finger is pointing up.
          (Remember: y=0 is top of frame, increases downward)

        - For thumb: we compare x coords because the thumb extends sideways.
          On a mirrored (flipped) frame:
          Right hand: thumb tip x > thumb base x means extended
          We use thumb tip vs landmark[2] (thumb IP joint)
        """
        up = []

        # THUMB — x-axis comparison (extended = tip is further right on mirrored frame)
        thumb_tip  = landmarks[FINGERTIP_IDS["thumb"]]
        thumb_base = landmarks[FINGERBASE_IDS["thumb"]]
        up.append(thumb_tip[0] > thumb_base[0])

        # INDEX, MIDDLE, RING, PINKY — y-axis comparison
        for name in ["index", "middle", "ring", "pinky"]:
            tip = landmarks[FINGERTIP_IDS[name]]
            pip = landmarks[FINGERPIP_IDS[name]]
            # tip.y < pip.y means tip is higher on screen = finger is up
            up.append(tip[1] < pip[1])

        return up

    def draw_hud(self, frame):
        """
        Shows the current gesture name on screen.
        Useful during development so you can see what's being detected.
        """
        from utils.overlay_utils import draw_text_with_bg

        # Color-code by gesture type
        color_map = {
            "click":        (0, 255, 0),     # Green
            "select_start": (0, 165, 255),   # Orange
            "select_end":   (0, 100, 255),   # Deep orange
            "drag":         (255, 255, 0),   # Yellow
            "erase":        (0, 0, 255),     # Red
            "draw":         (255, 0, 255),   # Magenta
            "filter_next":  (0, 255, 255),   # Cyan
            "idle":         (180, 180, 180), # Gray
            "none":         (80, 80, 80),    # Dark gray
        }
        color = color_map.get(self.gesture, (255, 255, 255))

        draw_text_with_bg(
            frame,
            f"Gesture: {self.gesture.upper()}",
            (10, 65),
            font_scale=0.6,
            text_color=color,
            bg_color=(0, 0, 0)
        )
        return frame


# -------------------------------------------------------------
# STANDALONE TEST
#   python modules/gesture_engine.py
# Show your hand and try each gesture. Press 'q' to quit.
# -------------------------------------------------------------
if __name__ == "__main__":
    import sys, cv2
    sys.path.insert(0, "..")

    from modules.hand_tracker import HandTracker

    cap     = cv2.VideoCapture(0, cv2.CAP_DSHOW)
    tracker = HandTracker()
    engine  = GestureEngine()

    print("Gesture engine test. Try gestures. Press 'q' to quit.")
    print("Gestures to try:")
    print("  - Pinch thumb+index  → click")
    print("  - Pinch thumb+middle → select_start / select_end")
    print("  - Index finger only  → draw")
    print("  - Index+middle up    → drag")
    print("  - Closed fist        → erase")
    print("  - Open palm          → filter_next")

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        frame = cv2.flip(frame, 1)
        landmarks = tracker.update(frame)
        gesture   = engine.update(landmarks)

        tracker.draw(frame)
        engine.draw_hud(frame)

        cv2.imshow("Gesture Engine Test", frame)
        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

    cap.release()
    cv2.destroyAllWindows()